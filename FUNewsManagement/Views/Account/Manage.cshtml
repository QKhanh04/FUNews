@model ViewModel.Account.AccountManagementViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Account Management";
}

<div class="space-y-8">
    <!-- Breadcrumbs -->
    <nav aria-label="Breadcrumb" class="flex text-sm font-medium text-slate-500 mb-6">
        <ol class="flex items-center space-x-2">
            <li><a asp-controller="Home" asp-action="Index" class="hover:text-primary transition-colors">Home</a></li>
            <li><span class="material-symbols-outlined text-base">chevron_right</span></li>
            <li class="text-slate-900 font-bold">@ViewData["Title"]</li>
        </ol>
    </nav>

    <!-- Page Title & Primary Actions -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-1">
            <h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Account Management</h2>
            <p class="text-slate-500 dark:text-slate-400 max-w-xl">
                Manage system users, assign roles and maintain account security. Control access for Admins, Staff and Lecturers.
            </p>
        </div>
        <button onclick="openAccountModal()" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white font-bold px-5 py-2.5 rounded-lg transition-all shadow-lg shadow-primary/20 shrink-0">
            <span class="material-symbols-outlined text-lg">person_add</span>
            <span>Create New Account</span>
        </button>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-5">
            <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-3xl">group</span>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500 text-nowrap">Total Users</p>
                <h3 class="text-2xl font-bold text-slate-900 dark:text-white">@Model.Stats.TotalAccounts</h3>
            </div>
        </div>
        <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-5">
            <div class="w-14 h-14 rounded-full bg-purple-100 flex items-center justify-center text-purple-600">
                <span class="material-symbols-outlined text-3xl">admin_panel_settings</span>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500 text-nowrap">Administrators</p>
                <h3 class="text-2xl font-bold text-slate-900 dark:text-white">@Model.Stats.AdminCount</h3>
            </div>
        </div>
        <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-5">
            <div class="w-14 h-14 rounded-full bg-blue-100 flex items-center justify-center text-blue-600">
                <span class="material-symbols-outlined text-3xl">badge</span>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500 text-nowrap">Staff Members</p>
                <h3 class="text-2xl font-bold text-slate-900 dark:text-white">@Model.Stats.StaffCount</h3>
            </div>
        </div>
        <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-5">
            <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center text-green-600">
                <span class="material-symbols-outlined text-3xl">person_add</span>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500 text-nowrap">New This Month</p>
                <h3 class="text-2xl font-bold text-slate-900 dark:text-white">@Model.Stats.NewAccountsThisMonth</h3>
            </div>
        </div>
    </div>

    <!-- Filters Bar -->
    <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
        <form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
            <div class="md:col-span-3 relative">
                <label class="block text-xs font-bold text-slate-500 uppercase mb-2 ml-1">Search User</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                    <input name="search" value="@Model.SearchTerm" class="w-full pl-10 pr-4 py-2 bg-slate-50 dark:bg-slate-800 border-none rounded-lg focus:ring-2 focus:ring-primary/50 text-slate-900 dark:text-white placeholder:text-slate-400 text-sm" placeholder="Search by name or email..."/>
                </div>
            </div>
            <div class="flex gap-2">
                <button type="submit" class="flex-1 bg-primary text-white font-bold py-2 rounded-lg hover:bg-primary/90 transition-colors text-sm">Search</button>
                <a asp-action="Manage" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-500 rounded-lg hover:bg-slate-200 transition-colors flex items-center">
                    <span class="material-symbols-outlined text-xl">restart_alt</span>
                </a>
            </div>
        </form>
    </div>

    <!-- Accounts Table -->
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Member</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Email Address</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Role</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Joined</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @foreach (var item in Model.Accounts)
                    {
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 font-bold text-sm">
                                        @item.FullName?.Substring(0, 1).ToUpper()
                                    </div>
                                    <p class="text-sm font-bold text-slate-900 dark:text-white">@item.FullName</p>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-500">@item.Email</td>
                            <td class="px-6 py-4">
                                @if (item.Role == 0) {
                                    <span class="px-2.5 py-1 rounded-full bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400 text-xs font-bold italic">Administrator</span>
                                } else if (item.Role == 1) {
                                    <span class="px-2.5 py-1 rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 text-xs font-bold">Staff Member</span>
                                } else {
                                    <span class="px-2.5 py-1 rounded-full bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400 text-xs font-bold">Lecturer</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-sm text-slate-500 font-medium">@item.CreatedAt?.ToString("MMM dd, yyyy")</td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2 text-primary">
                                    <button onclick='openAccountModal(@Json.Serialize(item))' class="p-1.5 hover:bg-primary/10 rounded transition-all" title="Edit Account">
                                        <span class="material-symbols-outlined text-xl">edit</span>
                                    </button>
                                    <button onclick="confirmDeleteAccount(@item.AccountId, '@item.FullName')" class="p-1.5 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded transition-all" title="Delete Account">
                                        <span class="material-symbols-outlined text-xl">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="px-6 py-4 bg-slate-50 dark:bg-slate-800/50 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
            <p class="text-sm text-slate-500 font-medium">Showing @(((Model.PageNumber - 1) * Model.PageSize) + 1) to @(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)) of @Model.TotalCount accounts</p>
            <div class="flex gap-2">
                @if (Model.PageNumber > 1) {
                    <a asp-action="Manage" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-search="@Model.SearchTerm" class="px-3 py-1 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded text-sm text-slate-600 hover:bg-slate-50 transition-colors">Prev</a>
                }
                <button class="px-3 py-1 bg-primary text-white rounded font-bold text-sm">@Model.PageNumber</button>
                @if (Model.PageNumber * Model.PageSize < Model.TotalCount) {
                    <a asp-action="Manage" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-search="@Model.SearchTerm" class="px-3 py-1 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded text-sm text-slate-600 hover:bg-slate-50 transition-colors">Next</a>
                }
            </div>
        </div>
    </div>
</div>

<!-- Account Create/Edit Modal -->
<div id="accountModal" class="fixed inset-0 z-[100] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="hideAccountModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div class="relative inline-block align-bottom bg-white dark:bg-slate-900 rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-xl sm:w-full">
            <form id="accountForm" method="post" action="">
                @Html.AntiForgeryToken()
                <input type="hidden" name="AccountId" id="modal_AccountId" />
                <div class="bg-white dark:bg-slate-900 px-4 pt-5 pb-4 sm:p-8 sm:pb-6">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <h3 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight" id="accountModalTitle">Configure Account</h3>
                            <p class="text-sm text-slate-500 mt-1">Set user profile details and access permissions.</p>
                        </div>
                        <button type="button" onclick="hideAccountModal()" class="text-slate-400 hover:text-slate-600 transition-colors">
                            <span class="material-symbols-outlined text-2xl">close</span>
                        </button>
                    </div>
                    
                    <div class="space-y-6">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Display Name</label>
                            <input type="text" name="AccountName" id="modal_AccountName" required
                                   class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/50 text-slate-900 dark:text-white font-semibold"
                                   placeholder="Full name of user..."/>
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Email Address</label>
                            <input type="email" name="AccountEmail" id="modal_AccountEmail" required
                                   class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/50 text-slate-900 dark:text-white"
                                   placeholder="user@university.edu.vn"/>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                             <div class="space-y-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Security Password</label>
                                <input type="password" name="AccountPassword" id="modal_AccountPassword"
                                       class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/50 text-slate-900 dark:text-white"
                                       placeholder="Leave blank to keep current..."/>
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Access Role</label>
                                <select name="AccountRole" id="modal_AccountRole" required
                                        class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/50 text-slate-900 dark:text-white text-sm">
                                    <option value="1">Staff Member</option>
                                    <option value="2">Lecturer</option>
                                    <option id="roleOptionAdmin" value="0">Administrator</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-slate-50 dark:bg-slate-800/50 px-4 py-4 sm:px-8 sm:flex sm:flex-row-reverse gap-3">
                    <button type="submit" class="w-full inline-flex justify-center rounded-xl border border-transparent shadow-lg shadow-primary/20 px-8 py-3 bg-primary text-base font-bold text-white hover:bg-primary/90 focus:outline-none sm:ml-3 sm:w-auto sm:text-sm transition-all">
                        Save Changes
                    </button>
                    <button type="button" onclick="hideAccountModal()" class="mt-3 w-full inline-flex justify-center rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm px-8 py-3 bg-white dark:bg-slate-900 text-base font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 transition-all sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Account Modal -->
<div id="deleteAccountModal" class="fixed inset-0 z-[100] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="hideDeleteAccountModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div class="relative inline-block align-bottom bg-white dark:bg-slate-900 rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
            <div class="bg-white dark:bg-slate-900 px-4 pt-5 pb-4 sm:p-8 sm:pb-6">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 text-red-600 sm:mx-0 sm:h-10 sm:w-10">
                        <span class="material-symbols-outlined text-2xl">person_remove</span>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
                        <h3 class="text-xl leading-6 font-bold text-slate-900 dark:text-white" id="modal-title">Delete Account</h3>
                        <div class="mt-3">
                            <p id="deleteAccountMessage" class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"></p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-slate-50 dark:bg-slate-800/50 px-4 py-4 sm:px-8 sm:flex sm:flex-row-reverse gap-3">
                <form id="deleteAccountForm" method="post" asp-action="Delete">
                    <input type="hidden" name="id" id="deleteAccountId"/>
                    <button type="submit" class="w-full inline-flex justify-center rounded-xl border border-transparent shadow-lg shadow-red-600/20 px-6 py-2.5 bg-red-600 text-base font-bold text-white hover:bg-red-700 focus:outline-none sm:ml-3 sm:w-auto sm:text-sm transition-all">
                        Remove
                    </button>
                </form>
                <button type="button" onclick="hideDeleteAccountModal()" class="mt-3 w-full inline-flex justify-center rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm px-6 py-2.5 bg-white dark:bg-slate-900 text-base font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 focus:outline-none sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm transition-all">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAccountModal(account = null) {
            const modal = document.getElementById('accountModal');
            const form = document.getElementById('accountForm');
            const title = document.getElementById('accountModalTitle');
            
            form.reset();

            const currentUserId = "@ViewBag.CurrentUserId";
            const isAdminEditingSelf = account && account.accountId.toString() === currentUserId;

            if (account) {
                title.innerText = 'Edit Account';
                form.action = '@Url.Action("Edit")';
                document.getElementById('modal_AccountId').value = account.accountId;
                document.getElementById('modal_AccountName').value = account.fullName;
                document.getElementById('modal_AccountEmail').value = account.email;
                document.getElementById('modal_AccountRole').value = account.role;
                
                // RESTRICTIONS:
                const emailInput = document.getElementById('modal_AccountEmail');
                const passwordInput = document.getElementById('modal_AccountPassword');
                const roleAdminOption = document.getElementById('roleOptionAdmin');

                if (isAdminEditingSelf) {
                    emailInput.disabled = false;
                    passwordInput.disabled = false;
                    passwordInput.placeholder = 'Leave blank to keep current...';
                    roleAdminOption.classList.remove('hidden');
                } else {
                    emailInput.disabled = true;
                    passwordInput.disabled = true;
                    passwordInput.placeholder = 'Only the user can change their password...';
                    roleAdminOption.classList.add('hidden');
                }

                document.getElementById('modal_AccountPassword').required = false;
            } else {
                title.innerText = 'New Account';
                form.action = '@Url.Action("Create")';
                document.getElementById('modal_AccountId').value = '0';
                
                document.getElementById('modal_AccountEmail').disabled = false;
                document.getElementById('modal_AccountPassword').disabled = false;
                document.getElementById('modal_AccountPassword').placeholder = 'Choose a strong password...';
                document.getElementById('modal_AccountPassword').required = true;
                document.getElementById('roleOptionAdmin').classList.add('hidden');
                document.getElementById('modal_AccountRole').value = "1"; // Default to Staff
            }
            
            modal.classList.remove('hidden');
            document.body.classList.add('overflow-hidden');
        }

        function hideAccountModal() {
            document.getElementById('accountModal').classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
        }

        function confirmDeleteAccount(id, name) {
            const modal = document.getElementById('deleteAccountModal');
            const message = document.getElementById('deleteAccountMessage');
            const deleteId = document.getElementById('deleteAccountId');

            deleteId.value = id;
            message.innerHTML = `Are you sure you want to permanently delete <strong>${name}</strong>? This user will no longer be able to sign in.`;
            
            modal.classList.remove('hidden');
            document.body.classList.add('overflow-hidden');
        }

        function hideDeleteAccountModal() {
            document.getElementById('deleteAccountModal').classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
        }

        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                hideAccountModal();
                hideDeleteAccountModal();
            }
        });
    </script>
}
