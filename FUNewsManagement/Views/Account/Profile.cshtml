@model ViewModel.Account.ProfileViewModel
@{
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    bool isStaffOrAdmin = userRole == "0" || userRole == "1";
    Layout = isStaffOrAdmin ? "_AdminLayout" : "_Layout";
    
    ViewData["Title"] = "My Profile";
    var userInitials = string.IsNullOrEmpty(Model.AccountName) ? "U"
        : string.Join("", Model.AccountName.Split(' ').Take(2).Select(w => w[0])).ToUpper();
    
    string roleName = Model.AccountRole switch {
        0 => "Administrator",
        1 => "Staff",
        2 => "Lecturer",
        _ => "User"
    };
}

<!-- Page Content -->
<div class="max-w-5xl mx-auto w-full">
    <!-- Breadcrumbs -->
    <nav aria-label="Breadcrumb" class="flex text-sm font-medium text-slate-500 dark:text-slate-400 mb-6">
        <ol class="flex items-center space-x-2">
            <li><a asp-controller="Home" asp-action="Index" class="hover:text-primary dark:hover:text-primary transition-colors">Home</a></li>
            <li><span class="material-symbols-outlined text-base">chevron_right</span></li>
            <li class="text-slate-900 dark:text-white">Profile</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="flex items-end justify-between mb-8">
        <div>
            <h2 class="text-3xl font-black tracking-tight mb-2 text-slate-900 dark:text-white">My Profile</h2>
            <p class="text-slate-500 dark:text-slate-400">Manage your personal information and security settings.</p>
        </div>
        <div class="flex gap-3">
            <button type="button" onclick="location.reload()" class="px-6 py-2 border border-slate-200 dark:border-slate-700 font-bold text-sm text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">Discard</button>
            <button type="submit" form="profileForm" class="px-6 py-2 bg-primary text-white font-bold text-sm rounded-lg hover:bg-primary/90 shadow-lg transition-all shadow-orange-500/20">Save Changes</button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Profile Picture Card -->
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm text-center">
                <div class="relative inline-block mb-4">
                    <div class="size-40 rounded-full border-4 border-slate-50 dark:border-slate-800 shadow-xl flex items-center justify-center bg-primary text-white text-5xl font-black">
                        @userInitials
                    </div>
                    <button class="absolute bottom-1 right-1 bg-primary text-white p-2 rounded-full border-4 border-white hover:scale-105 transition-transform">
                        <span class="material-symbols-outlined text-lg">edit</span>
                    </button>
                </div>
                <h3 class="text-lg font-bold text-slate-900 dark:text-white">@Model.AccountName</h3>
                <p class="text-slate-500 dark:text-slate-400 text-sm mb-6">@roleName</p>
                <button type="button" class="w-full py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 font-bold text-sm rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                    Upload New Photo
                </button>
                <p class="text-[10px] text-slate-400 dark:text-slate-500 mt-4 leading-relaxed uppercase tracking-wider font-bold">Allowed JPG, GIF or PNG. Max size of 2MB</p>
            </div>
        </div>

        <!-- Main Form Section -->
        <div class="lg:col-span-2 space-y-8">
            <!-- General Information -->
            <section class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">person</span>
                    <h3 class="font-bold text-slate-900 dark:text-white">General Information</h3>
                </div>
                <div class="p-6">
                    <form asp-controller="Account" asp-action="UpdateProfile" method="post" id="profileForm" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <input type="hidden" asp-for="AccountId" />
                        
                        <div class="space-y-1.5">
                            <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Account ID</label>
                            <input class="w-full bg-slate-100 dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg text-sm text-slate-500 dark:text-slate-400 cursor-not-allowed px-4 py-2.5" disabled type="text" value="ACC-@Model.AccountId" />
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="AccountName" class="text-sm font-bold text-slate-700 dark:text-slate-300">Account Name</label>
                            <input asp-for="AccountName" class="w-full bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-primary focus:border-primary px-4 py-2.5 dark:text-white" />
                            <span asp-validation-for="AccountName" class="text-xs text-red-500"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label class="text-sm font-bold text-slate-700 dark:text-slate-300 flex items-center gap-1.5">
                                Account Email
                                <span class="material-symbols-outlined text-slate-400 text-xs">lock</span>
                            </label>
                            <input class="w-full bg-slate-100 dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg text-sm text-slate-500 dark:text-slate-400 cursor-not-allowed px-4 py-2.5" disabled type="email" asp-for="AccountEmail" />
                        </div>

                        <div class="space-y-1.5">
                            <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Account Role</label>
                            <div class="px-4 py-2.5 bg-slate-100 dark:bg-slate-800 rounded-lg flex items-center">
                                <span class="text-sm font-bold text-primary">@roleName</span>
                            </div>
                        </div>

                        @if (Model.IsGoogleAccount)
                        {
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Google Account Status</label>
                                <div class="flex items-center gap-2 px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg">
                                    <img class="size-4" src="https://www.gstatic.com/images/branding/product/1x/googleg_48dp.png" />
                                    <span class="text-sm font-medium dark:text-slate-300">Linked</span>
                                    <span class="ml-auto bg-green-500/10 text-green-500 text-[10px] font-bold px-1.5 py-0.5 rounded">Active</span>
                                </div>
                            </div>

                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Google ID</label>
                                <input class="w-full bg-slate-100 dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg text-sm text-slate-500 dark:text-slate-400 cursor-not-allowed px-4 py-2.5" disabled type="text" asp-for="GoogleId" />
                            </div>
                        }

                        <div class="md:col-span-2 space-y-1.5">
                            <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Created At</label>
                            <input class="w-full bg-slate-100 dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg text-sm text-slate-500 dark:text-slate-400 cursor-not-allowed px-4 py-2.5" disabled type="text" value="@(Model.CreatedAt?.ToString("MMMM dd, yyyy at hh:mm tt") ?? "N/A")" />
                        </div>
                    </form>
                </div>
            </section>

            <!-- Password Update -->
            <section class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">security</span>
                        <h3 class="font-bold text-slate-900 dark:text-white">Update Password</h3>
                    </div>
                    <span class="text-[10px] font-bold text-primary uppercase tracking-widest px-2 py-1 bg-primary/5 rounded">Security Level: High</span>
                </div>
                <div class="p-6">
                    <form asp-controller="Account" asp-action="ChangePassword" method="post" class="space-y-6">
                        <input type="hidden" asp-for="AccountId" />
                        <div class="space-y-1.5">
                            <label asp-for="CurrentPassword" class="text-sm font-bold text-slate-700 dark:text-slate-300">Current Password</label>
                            <div class="relative">
                                <input asp-for="CurrentPassword" type="password" value="@Model.CurrentPassword" class="w-full bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-primary focus:border-primary pr-10 px-4 py-2.5 dark:text-white" placeholder="Enter current password" />
                                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg cursor-pointer toggle-password">visibility</span>
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-xs text-red-500"></span>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-1.5">
                                <label asp-for="NewPassword" class="text-sm font-bold text-slate-700 dark:text-slate-300">New Password</label>
                                <div class="relative">
                                    <input asp-for="NewPassword" type="password" value="@Model.NewPassword" class="w-full bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-primary focus:border-primary px-4 py-2.5 pr-10 dark:text-white" placeholder="Min. 8 characters" />
                                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg cursor-pointer toggle-password">visibility</span>
                                </div>
                                <span asp-validation-for="NewPassword" class="text-xs text-red-500"></span>
                            </div>
                            <div class="space-y-1.5">
                                <label asp-for="ConfirmPassword" class="text-sm font-bold text-slate-700 dark:text-slate-300">Confirm New Password</label>
                                <div class="relative">
                                    <input asp-for="ConfirmPassword" type="password" value="@Model.ConfirmPassword" class="w-full bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-primary focus:border-primary px-4 py-2.5 pr-10 dark:text-white" placeholder="Re-type new password" />
                                    <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg cursor-pointer toggle-password">visibility</span>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-xs text-red-500"></span>
                            </div>
                        </div>

                        <div class="bg-slate-50 dark:bg-slate-800/50 p-4 rounded-lg border border-slate-200 dark:border-slate-700">
                            <p class="text-xs font-bold text-slate-600 dark:text-slate-400 mb-2">Password Requirements:</p>
                            <ul class="text-[11px] text-slate-500 space-y-1 ml-4 list-none p-0">
                                <li id="req-length" class="flex items-center gap-2 transition-colors duration-300">
                                    <span class="material-symbols-outlined text-sm">circle</span>
                                    <span>At least 8 characters long</span>
                                </li>
                                <li id="req-upper" class="flex items-center gap-2 transition-colors duration-300">
                                    <span class="material-symbols-outlined text-sm">circle</span>
                                    <span>Contains at least one uppercase letter</span>
                                </li>
                                <li id="req-special" class="flex items-center gap-2 transition-colors duration-300">
                                    <span class="material-symbols-outlined text-sm">circle</span>
                                    <span>Contains at least one number or symbol</span>
                                </li>
                            </ul>
                        </div>

                        <div class="flex justify-end">
                            <button type="submit" class="px-6 py-2 bg-primary text-white font-bold text-sm rounded-lg hover:bg-primary/90 shadow-md transition-all">Update Password</button>
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Password Visibility Toggle
            $('.toggle-password').click(function() {
                const input = $(this).siblings('input');
                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    $(this).text('visibility_off');
                } else {
                    input.attr('type', 'password');
                    $(this).text('visibility');
                }
            });

            // Password Requirement Tracker
            const newPwd = $('#NewPassword');
            const reqLength = $('#req-length');
            const reqUpper = $('#req-upper');
            const reqSpecial = $('#req-special');

            function updateReq(el, isValid) {
                const icon = el.find('.material-symbols-outlined');
                if (isValid) {
                    el.removeClass('text-slate-500').addClass('text-green-500 font-bold');
                    icon.text('check_circle').css('font-variation-settings', "'FILL' 1");
                } else {
                    el.removeClass('text-green-500 font-bold').addClass('text-slate-500');
                    icon.text('circle').css('font-variation-settings', "'FILL' 0");
                }
            }

            newPwd.on('keyup input', function() {
                const val = $(this).val();
                
                // 8 characters
                updateReq(reqLength, val.length >= 8);
                
                // Uppercase letter
                updateReq(reqUpper, /[A-Z]/.test(val));
                
                // Number or symbol
                updateReq(reqSpecial, /[0-9!@@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(val));
            });
        });
    </script>
}
