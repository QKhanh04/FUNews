@model IEnumerable<ViewModel.Home.NewsCardViewModel>

@foreach (var article in Model)
{
        <article class="flex flex-col bg-white dark:bg-slate-800 rounded-xl overflow-hidden shadow-sm border border-slate-200 dark:border-slate-700 hover:shadow-md transition-shadow group">
            <div class="relative aspect-video overflow-hidden bg-slate-100 dark:bg-slate-700">
            @if (!string.IsNullOrWhiteSpace(article.ThumbnailUrl))
            {
                        <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                             src="@article.ThumbnailUrl"
                             alt="@article.NewsTitle" />
            }
            else
            {
                        <div class="w-full h-full flex items-center justify-center bg-slate-200 dark:bg-slate-800/50">
                            <span class="material-symbols-outlined text-5xl text-slate-400 dark:text-slate-500">newspaper</span>
                        </div>
            }
            @if (!string.IsNullOrWhiteSpace(article.CategoryName))
            {
                        <div class="absolute top-3 left-3">
                            <span class="px-2 py-1 bg-slate-900/60 backdrop-blur-md text-white text-[10px] font-bold uppercase rounded">
                        @article.CategoryName
                            </span>
                        </div>
            }
            </div>
            <div class="p-5 flex flex-col grow">
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2 leading-tight group-hover:text-primary transition-colors line-clamp-2">
                @article.NewsTitle
                </h3>
                <p class="text-slate-600 dark:text-slate-400 text-sm line-clamp-3 mb-4">
                @article.Headline
                </p>
                <div class="mt-auto flex items-center justify-between pt-4">
                    <span class="text-slate-400 dark:text-slate-500 text-[11px] font-bold uppercase tracking-wider">
                    @(article.CreatedDate?.ToString("MMM dd, yyyy") ?? "")
                    </span>
                    <a asp-controller="News" asp-action="Detail" asp-route-id="@article.NewsArticleId"
                       style="color: #f57a00 !important;"
                       class="text-primary text-[13px] font-black flex items-center gap-1 hover:underline group/link">
                        Read More
                        <span class="material-symbols-outlined text-[18px] group-hover/link:translate-x-1 transition-transform">arrow_forward</span>
                    </a>
                </div>
            </div>
        </article>
}
