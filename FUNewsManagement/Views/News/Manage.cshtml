@model ViewModel.News.NewsManagementViewModel
@{
	Layout = "_AdminLayout";
	ViewData["Title"] = "News Management";
	var categories = ViewBag.Categories as IEnumerable<DataAccessObjects.Category> ?? new List<DataAccessObjects.Category>();
}

@section Styles {
		<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
		<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
		<script>
			tailwind.config = {
				darkMode: "class",
				theme: {
					extend: {
						colors: {
							"primary": "#f27121",
							"primary-hover": "#e66416",
						}
					},
				},
			}
		</script>
		<style>
			.custom-scrollbar::-webkit-scrollbar { width: 5px; height: 5px; }
			.custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
			.custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
			.dark .custom-scrollbar::-webkit-scrollbar-thumb { background: #475569; }
				#modal_CategoryId {
		-webkit-appearance: none;
		-moz-appearance: none;
		appearance: none;
		background-image: none !important;
	}

			#newsModal .modal-container { max-height: 92vh; }

			/* Quill Editor Tweaks */
			.ql-container { font-family: 'Inter', sans-serif !important; font-size: 15px !important; border-bottom-left-radius: 12px; border-bottom-right-radius: 12px; }
			.ql-toolbar { border-top-left-radius: 12px; border-top-right-radius: 12px; background: #f8fafc; border-color: #e2e8f0 !important; }
			.dark .ql-toolbar { background: #1e293b; border-color: #334155 !important; }
			.dark .ql-container { border-color: #334155 !important; color: #cbd5e1; }
			.ql-editor { min-height: 200px; max-height: 400px; overflow-y: auto; }
			.ql-editor.ql-blank::before { color: #94a3b8 !important; font-style: normal; }
		</style>
}

<div class="space-y-8">
	<!-- Breadcrumbs -->
	<nav aria-label="Breadcrumb" class="flex text-sm font-medium text-slate-500 dark:text-slate-400 mb-6">
		<ol class="flex items-center space-x-2">
			<li><a asp-controller="Home" asp-action="Index" class="hover:text-primary transition-colors">Home</a></li>
			<li><span class="material-symbols-outlined text-base">chevron_right</span></li>
			<li class="text-slate-900 dark:text-white font-bold">@ViewData["Title"]</li>
		</ol>
	</nav>

	<!-- Page Title & Primary Actions -->
	<div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
		<div class="space-y-1">
			<h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">News Management</h2>
			<p class="text-slate-500 dark:text-slate-400 max-w-xl">
				Create, edit and manage university news articles. Keep the community informed with the latest updates.
			</p>
		</div>
		<button onclick="openNewsModal()" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white font-bold px-5 py-2.5 rounded-lg transition-all shadow-lg shadow-primary/20 shrink-0">
			<span class="material-symbols-outlined text-lg">add_circle</span>
			<span>Create News Article</span>
		</button>
	</div>

	<!-- Statistics Cards -->
	<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
		<div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-5">
			<div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center text-primary">
				<span class="material-symbols-outlined text-3xl">article</span>
			</div>
			<div>
				<p class="text-sm font-medium text-slate-500 text-nowrap">Total Articles</p>
				<h3 class="text-2xl font-bold text-slate-900 dark:text-white">@Model.Stats.TotalArticles</h3>
			</div>
		</div>
		<div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-5">
			<div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center text-green-600">
				<span class="material-symbols-outlined text-3xl">public</span>
			</div>
			<div>
				<p class="text-sm font-medium text-slate-500 text-nowrap">Active News</p>
				<h3 class="text-2xl font-bold text-slate-900 dark:text-white">@Model.Stats.ActiveArticles</h3>
			</div>
		</div>
		<div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-5">
			<div class="w-14 h-14 rounded-full bg-orange-100 flex items-center justify-center text-orange-600">
				<span class="material-symbols-outlined text-3xl">edit_document</span>
			</div>
			<div>
				<p class="text-sm font-medium text-slate-500 text-nowrap">Drafts</p>
				<h3 class="text-2xl font-bold text-slate-900 dark:text-white">@Model.Stats.DraftArticles</h3>
			</div>
		</div>
	</div>

	<!-- Filters Bar -->
	<div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
		<form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
			<div class="md:col-span-2 relative">
				<label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase mb-2 ml-1">Search Keywords</label>
				<div class="relative">
					<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
					<input name="search" value="@Model.SearchTerm" class="w-full pl-10 pr-4 py-2 bg-slate-50 dark:bg-slate-800 border-none rounded-lg focus:ring-2 focus:ring-primary/50 text-slate-900 dark:text-white placeholder:text-slate-400 text-sm" placeholder="Title, headline, or content..."/>
				</div>
			</div>
			<div>
				<label class="block text-xs font-bold text-slate-500 dark:text-slate-400 uppercase mb-2 ml-1">Category</label>
				<select name="categoryId" class="w-full py-2 bg-slate-50 dark:bg-slate-800 border-none rounded-lg focus:ring-2 focus:ring-primary/50 text-slate-900 dark:text-white text-sm">
					<option value="">All Categories</option>
					@foreach (var cat in categories)
					{
							<option value="@cat.CategoryId" selected="@(Model.CategoryId == cat.CategoryId)">@cat.CategoryName</option>
					}
				</select>
			</div>
			<div class="flex gap-2">
				<button type="submit" class="flex-1 bg-primary text-white font-bold py-2 rounded-lg hover:bg-primary/90 transition-colors text-sm">Apply</button>
				<a asp-action="Manage" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors flex items-center">
					<span class="material-symbols-outlined text-xl">restart_alt</span>
				</a>
			</div>
		</form>
	</div>

	<!-- News Table -->
	<div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
		<div class="overflow-x-auto">
			<table class="w-full text-left border-collapse">
				<thead>
					<tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
						<th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Article</th>
						<th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Category</th>
						<th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Author</th>
						<th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Status</th>
						<th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-right">Actions</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-slate-100 dark:divide-slate-800">
					@foreach (var item in Model.Articles)
					{
							<tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/50 transition-colors">
								<td class="px-6 py-4">
									<div class="flex items-center gap-4">
										<div class="size-12 rounded-lg bg-slate-100 overflow-hidden flex-shrink-0">
										@if (!string.IsNullOrEmpty(item.ThumbnailUrl))
										{
													<img src="@item.ThumbnailUrl" class="w-full h-full object-cover" />
										}
										else
										{
													<div class="w-full h-full flex items-center justify-center text-slate-400">
														<span class="material-symbols-outlined">image</span>
													</div>
										}
										</div>
										<div>
											<p class="text-sm font-bold text-slate-900 dark:text-white line-clamp-1">@item.NewsTitle</p>
											<p class="text-xs text-slate-500 mt-0.5">@item.CreatedDate?.ToString("MMM dd, yyyy")</p>
										</div>
									</div>
								</td>
								<td class="px-6 py-4">
									<span class="px-2.5 py-1 rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 text-xs font-bold">@item.CategoryName</span>
								</td>
								<td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400 font-medium">@item.CreatedByName</td>
								<td class="px-6 py-4">
								@if (item.NewsStatus == true)
								{
											<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 text-xs font-bold">
												<span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Active
											</span>
								}
								else
								{
											<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400 text-xs font-bold">
												<span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span> Draft
											</span>
								}
								</td>
								<td class="px-6 py-4 text-right">
									<div class="flex items-center justify-end gap-2 text-primary">
										<a asp-action="Detail" asp-route-id="@item.NewsArticleId" target="_blank" class="p-1.5 hover:bg-primary/10 rounded transition-all" title="View Article">
											<span class="material-symbols-outlined text-xl">visibility</span>
										</a>
										<button onclick='openNewsModal(@Json.Serialize(item))' class="p-1.5 hover:bg-primary/10 rounded transition-all" title="Edit Article">
											<span class="material-symbols-outlined text-xl">edit</span>
										</button>
										<button onclick="confirmDeleteNews(@item.NewsArticleId, '@item.NewsTitle')" class="p-1.5 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded transition-all" title="Delete Article">
											<span class="material-symbols-outlined text-xl">delete</span>
										</button>
									</div>
								</td>
							</tr>
					}
				</tbody>
			</table>
		</div>
		<!-- Pagination -->
		<div class="px-6 py-4 bg-slate-50 dark:bg-slate-800/50 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
			<p class="text-sm text-slate-500 font-medium">Showing @(((Model.PageNumber - 1) * Model.PageSize) + 1) to @(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)) of @Model.TotalCount articles</p>
			<div class="flex gap-2">
				@if (Model.PageNumber > 1)
				{
						<a asp-action="Manage" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-search="@Model.SearchTerm" asp-route-categoryId="@Model.CategoryId" class="px-3 py-1 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded text-sm text-slate-600 hover:bg-slate-50 transition-colors">Prev</a>
				}
				<button class="px-3 py-1 bg-primary text-white rounded font-bold text-sm">@Model.PageNumber</button>
				@if (Model.PageNumber * Model.PageSize < Model.TotalCount)
				{
						<a asp-action="Manage" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-search="@Model.SearchTerm" asp-route-categoryId="@Model.CategoryId" class="px-3 py-1 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded text-sm text-slate-600 hover:bg-slate-50 transition-colors">Next</a>
				}
			</div>
		</div>
	</div>
</div>

<!-- News Create/Edit Modal -->
<div id="newsModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4" role="dialog" aria-modal="true">
	<!-- Backdrop with deeper blur -->
	<div class="absolute inset-0 bg-slate-900/40 backdrop-blur-[2px] transition-opacity" onclick="hideNewsModal()"></div>

	<!-- Modal Container -->
	<div class="modal-container relative bg-white dark:bg-slate-900 w-full max-w-5xl flex flex-col rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.15)] overflow-hidden border border-slate-200 dark:border-slate-800 animate-in fade-in zoom-in duration-300">
		<form id="newsForm" method="post" action="" enctype="multipart/form-data" class="flex flex-col h-full overflow-hidden">
			@Html.AntiForgeryToken()
			<input type="hidden" name="NewsArticleId" id="modal_NewsArticleId" />

			<!-- Modal Header -->
			<div class="px-8 py-5 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between flex-shrink-0">
				<div>
					<h2 class="text-2xl font-bold text-slate-900 dark:text-white leading-none" id="newsModalTitle">Edit News Article</h2>
					<p class="text-xs text-slate-400 mt-2 font-medium">Fill in the details to publish a new university update.</p>
				</div>
				<button type="button" onclick="hideNewsModal()" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-400 hover:text-slate-600 transition-all">
					<span class="material-symbols-outlined text-2xl">close</span>
				</button>
			</div>

			<!-- Modal Body (Simplified Vertical Layout) -->
			<div class="flex-1 overflow-y-auto p-8 custom-scrollbar min-h-0 bg-white dark:bg-slate-900">
				<div class="max-w-5xl mx-auto space-y-10">
					<!-- Main Story -->
					<section class="space-y-6">

						<div>
							<label class="block text-[13px] font-bold text-slate-700 dark:text-slate-300 mb-2.5">News Title <span class="text-red-500 font-black">*</span></label>
							<input name="NewsTitle" id="modal_NewsTitle" required 
								   class="w-full px-5 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all text-slate-900 dark:text-white font-medium placeholder:text-slate-400 text-lg shadow-sm" 
								   placeholder="Enter a compelling title..."/>
						</div>

						<div>
							<label class="block text-[13px] font-bold text-slate-700 dark:text-slate-300 mb-2.5">Headline (Introduction)</label>
							<input name="Headline" id="modal_Headline" 
								   class="w-full px-5 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all text-slate-900 dark:text-white font-medium placeholder:text-slate-400 shadow-sm" 
								   placeholder="Summarize your story in one sentence..."/>
						</div>

						<div>
							<label class="block text-[13px] font-bold text-slate-700 dark:text-slate-300 mb-2.5">Detailed Content</label>
							<div id="editor-container" class="rounded-xl shadow-sm overflow-hidden"></div>
							<input type="hidden" name="NewsContent" id="modal_NewsContent" required />
						</div>
					</section>

					<!-- Divider -->
					<div class="h-px bg-gradient-to-r from-transparent via-slate-200 dark:via-slate-700 to-transparent opacity-50"></div>

					<!-- Meta & Media -->
					<section class="grid grid-cols-1 md:grid-cols-2 gap-8">
						<!-- Left: Image & Category -->
						<div class="space-y-8">
							<div>

								<label class="block text-[13px] font-bold text-slate-700 dark:text-slate-300 mb-2.5">Featured Image</label>
								<div class="space-y-4">
									<div id="image_preview_container" class="hidden">
										<div class="relative group aspect-video rounded-2xl overflow-hidden border-2 border-primary/20 bg-slate-100 dark:bg-slate-900 shadow-md">
											<img id="image_preview" src="#" alt="Preview" class="w-full h-full object-cover">
											<div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
												<button type="button" onclick="clearImagePreview()" class="w-10 h-10 bg-red-500 text-white rounded-xl flex items-center justify-center hover:scale-110 transition-transform shadow-lg">
													<span class="material-symbols-outlined">delete</span>
												</button>
											</div>
										</div>
									</div>

									<div onclick="document.getElementById('modal_ThumbnailFile').click()" 
										 class="flex flex-col items-center justify-center border-2 border-dashed border-slate-200 dark:border-slate-700 rounded-2xl p-6 hover:border-primary hover:bg-primary/5 transition-all cursor-pointer group bg-slate-50/50 dark:bg-slate-800/30">
										<span class="material-symbols-outlined text-2xl text-slate-400 group-hover:text-primary mb-2 transition-colors">upload_file</span>
										<p class="text-[12px] text-slate-500"><span class="text-primary font-bold">Upload</span> or drag image</p>
										<input type="file" name="ThumbnailFile" id="modal_ThumbnailFile" accept="image/*" onchange="handleFileSelect(this)" class="hidden"/>
									</div>

									<div class="relative py-2">
										<div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-200 dark:border-slate-700"></div></div>
										<div class="relative flex justify-center"><span class="px-3 bg-white dark:bg-slate-900 text-[10px] text-slate-400 uppercase font-bold">OR</span></div>
									</div>

									<input name="ThumbnailUrl" id="modal_ThumbnailUrl" 
										   class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all text-xs font-medium placeholder:text-slate-400 shadow-sm" 
										   placeholder="External Image URL..."/>
								</div>
							</div>

							<div>
								<label class="block text-[13px] font-bold text-slate-700 dark:text-slate-300 mb-2.5">Category</label>
								<div class="relative">
									<select name="CategoryId" id="modal_CategoryId" required 
											class="w-full px-5 py-3.5 appearance-none rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all text-slate-900 dark:text-white text-sm font-bold shadow-sm cursor-pointer">
										<option value="">Select Category</option>
										@foreach (var cat in categories)
										{
												<option value="@cat.CategoryId">@cat.CategoryName</option>
										}
									</select>
									<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">expand_more</span>
								</div>
							</div>
						</div>

						<!-- Right: Tags & Status -->
						<div class="space-y-8">


							<div>
								<label class="block text-[13px] font-bold text-slate-700 dark:text-slate-300 mb-2.5">Tags</label>
								<div class="p-5 rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50/10 dark:bg-slate-800/20 shadow-inner">
									<div id="tag_checkbox_list" class="grid grid-cols-2 gap-2.5 max-h-48 overflow-y-auto mb-5 custom-scrollbar pr-2">
										@foreach (var tag in ViewBag.AllTags as IEnumerable<DataAccessObjects.Tag> ?? new List<DataAccessObjects.Tag>())
										{
												<label class="flex items-center gap-2.5 p-2 hover:bg-white dark:hover:bg-slate-800 rounded-lg cursor-pointer group transition-all border border-transparent hover:border-slate-100 dark:hover:border-slate-700 shadow-none hover:shadow-sm">
													<input type="checkbox" name="selectedTagIds" value="@tag.TagId" class="tag-checkbox w-4.5 h-4.5 rounded-md border-slate-300 text-primary focus:ring-primary transition-all" data-tag-id="@tag.TagId">
													<span class="text-[12px] font-semibold text-slate-500 dark:text-slate-400 group-hover:text-primary transition-colors">@tag.TagName</span>
												</label>
										}
									</div>
									<div class="flex gap-2 pt-4 border-t border-slate-200 dark:border-slate-700">
										<input id="add_tag_input" class="flex-1 px-4 py-2.5 text-xs rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 outline-none focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-medium" placeholder="Search or create tag..."/>
										<button type="button" onclick="addNewTagDynamic()" class="px-5 py-2.5 bg-primary text-white rounded-xl transition-all flex items-center justify-center text-[12px] font-black">
											 Add
										</button>
										<input type="hidden" name="newTags" id="modal_newTags" />
									</div>
								</div>
							</div>

							<!-- Publish toggle -->
							<div class="px-5 py-4 bg-slate-50 dark:bg-slate-800/30 rounded-xl flex items-center justify-between border border-slate-100 dark:border-slate-700/50">
								<div>
									<p class="text-[13px] font-bold text-slate-700 dark:text-slate-300">Publish Immediately</p>
									<p class="text-[10px] text-slate-400 font-medium mt-0.5">Visible to users right away</p>
								</div>
								<label class="relative inline-flex items-center cursor-pointer">
									<input type="checkbox" name="NewsStatus" id="modal_NewsStatus" value="true" class="sr-only peer">
									<div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer dark:bg-slate-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-primary"></div>
									<input type="hidden" name="NewsStatus" id="modal_NewsStatus_Hidden" value="false" />
								</label>
							</div>
						</div>
					</section>
				</div>
			</div>

			<!-- Modal Footer (Fixed at bottom) -->
			<div class="px-8 py-5 border-t border-slate-100 dark:border-slate-800 flex items-center justify-end gap-3 bg-white dark:bg-slate-900 flex-shrink-0">
				<button type="button" onclick="hideNewsModal()" class="px-6 py-3 rounded-xl border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 font-bold hover:bg-slate-50 dark:hover:bg-slate-800 transition-all text-sm">
					Discard Changes
				</button>
				<button type="submit" onclick="document.getElementById('modal_NewsStatus').checked = true;" 
						class="px-10 py-3 rounded-xl bg-primary hover:bg-primary-hover text-white font-bold shadow-xl shadow-primary/20 transition-all flex items-center gap-2.5 text-sm active:scale-95">
					<span class="material-symbols-outlined text-xl">publish</span>
					Save Article
				</button>
			</div>
		</form>
	</div>
</div>

<!-- Delete News Modal -->
<div id="deleteNewsModal" class="fixed inset-0 z-[100] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
	<div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
		<div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="hideDeleteNewsModal()"></div>
		<span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
		<div class="relative inline-block align-bottom bg-white dark:bg-slate-900 rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
			<div class="bg-white dark:bg-slate-900 px-4 pt-5 pb-4 sm:p-8 sm:pb-6">
				<div class="sm:flex sm:items-start">
					<div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 text-red-600 sm:mx-0 sm:h-10 sm:w-10">
						<span class="material-symbols-outlined text-2xl">warning</span>
					</div>
					<div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
						<h3 class="text-xl leading-6 font-bold text-slate-900 dark:text-white" id="modal-title">Remove Article</h3>
						<div class="mt-3">
							<p id="deleteNewsMessage" class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"></p>
						</div>
					</div>
				</div>
			</div>
			<div class="bg-slate-50 dark:bg-slate-800/50 px-4 py-4 sm:px-8 sm:flex sm:flex-row-reverse gap-3">
				<form id="deleteNewsForm" method="post" asp-action="Delete">
					<input type="hidden" name="id" id="deleteNewsId"/>
					<button type="submit" class="w-full inline-flex justify-center rounded-xl border border-transparent shadow-lg shadow-red-600/20 px-6 py-2.5 bg-red-600 text-base font-bold text-white hover:bg-red-700 focus:outline-none sm:ml-3 sm:w-auto sm:text-sm transition-all">
						Remove
					</button>
				</form>
				<button type="button" onclick="hideDeleteNewsModal()" class="mt-3 w-full inline-flex justify-center rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm px-6 py-2.5 bg-white dark:bg-slate-900 text-base font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 focus:outline-none sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm transition-all">
					Keep It
				</button>
			</div>
		</div>
	</div>
</div>

@section Scripts {
		<script>
			// Initialize Quill Editor
			const quill = new Quill('#editor-container', {
				theme: 'snow',
				placeholder: 'Share the details of your story...',
				modules: {
					toolbar: [
						[{ 'header': [1, 2, 3, false] }],
						['bold', 'italic', 'underline', 'strike'],
						[{ 'list': 'ordered'}, { 'list': 'bullet' }],
						['link', 'blockquote', 'code-block'],
						['clean']
					]
				}
			});

			// Sync Quill content to hidden input on every change
			quill.on('text-change', function() {
				document.getElementById('modal_NewsContent').value = quill.root.innerHTML;
			});

			// Dynamic Tag Management
			const newTagsArray = [];
			const tagListContainer = document.getElementById('tag_checkbox_list');
			const newTagsInput = document.getElementById('modal_newTags');
			const tagAddInput = document.getElementById('add_tag_input');

			function addNewTagDynamic() {
				const tagName = tagAddInput.value.trim();
				if (!tagName) return;

				// Check if tag already exists in checkbox list
				const existingTags = Array.from(tagListContainer.querySelectorAll('span')).map(s => s.innerText.toLowerCase());
				if (existingTags.includes(tagName.toLowerCase())) {
					const cb = Array.from(tagListContainer.querySelectorAll('label')).find(l => l.querySelector('span').innerText.toLowerCase() === tagName.toLowerCase()).querySelector('input');
					cb.checked = true;
					tagAddInput.value = '';
					return;
				}

				// Create new dynamic checkbox
				const tagId = 'new_' + Date.now();
				const label = document.createElement('label');
				label.className = "flex items-center gap-2.5 p-2 hover:bg-white dark:hover:bg-slate-800 rounded-lg cursor-pointer group transition-all border border-transparent hover:border-slate-100 dark:hover:border-slate-700 shadow-none hover:shadow-sm animate-in fade-in slide-in-from-left-2";
				label.innerHTML = `
					<input type="checkbox" checked onchange="updateNewTagsBackend()" class="new-tag-dynamic w-4.5 h-4.5 rounded-md border-slate-300 text-primary focus:ring-primary transition-all" value="${tagName}">
					<span class="text-[12px] font-semibold text-slate-500 dark:text-slate-400 group-hover:text-primary transition-colors">${tagName}</span>
				`;
				tagListContainer.prepend(label);
				tagAddInput.value = '';

				updateNewTagsBackend();
			}

			function updateNewTagsBackend() {
				const dynamicTags = Array.from(document.querySelectorAll('.new-tag-dynamic:checked')).map(cb => cb.value);
				newTagsInput.value = dynamicTags.join(',');
			}

			// Support Enter key for adding tag
			tagAddInput.addEventListener('keydown', (e) => {
				if (e.key === 'Enter') { e.preventDefault(); addNewTagDynamic(); }
			});

			function openNewsModal(news = null) {
				const modal = document.getElementById('newsModal');
				const form = document.getElementById('newsForm');
				const title = document.getElementById('newsModalTitle');

				form.reset();
				quill.root.innerHTML = '';
				document.querySelectorAll('.tag-checkbox').forEach(cb => cb.checked = false);
				document.querySelectorAll('.new-tag-dynamic').forEach(el => el.parentElement.remove());
				document.getElementById('modal_newTags').value = '';
				hideImagePreview();

				if (news) {
					title.innerText = 'Edit News Article';
					form.action = '@Url.Action("Edit")';
					document.getElementById('modal_NewsArticleId').value = news.newsArticleId;
					document.getElementById('modal_NewsTitle').value = news.newsTitle;
					document.getElementById('modal_Headline').value = news.headline;

					// Set Quill content
					quill.root.innerHTML = news.newsContent || '';
					document.getElementById('modal_NewsContent').value = news.newsContent || '';

					document.getElementById('modal_CategoryId').value = news.categoryId;
					document.getElementById('modal_ThumbnailUrl').value = news.thumbnailUrl || '';
					document.getElementById('modal_NewsStatus').checked = news.newsStatus;

					if (news.thumbnailUrl) updateImagePreview(news.thumbnailUrl);

					if (news.selectedTagIds && news.selectedTagIds.length > 0) {
						news.selectedTagIds.forEach(id => {
							const cb = document.querySelector(`.tag-checkbox[data-tag-id="${id}"]`);
							if (cb) cb.checked = true;
						});
					}
				} else {
					title.innerText = 'Create News Article';
					form.action = '@Url.Action("Create")';
					document.getElementById('modal_NewsArticleId').value = '0';
					document.getElementById('modal_NewsStatus').checked = true;
				}

				modal.classList.remove('hidden');
				document.body.classList.add('overflow-hidden');
			}

			const urlInput = document.getElementById('modal_ThumbnailUrl');
			const fileInput = document.getElementById('modal_ThumbnailFile');
			const previewImg = document.getElementById('image_preview');
			const previewContainer = document.getElementById('image_preview_container');

			urlInput.addEventListener('input', function() {
				const url = this.value.trim();
				if (url) updateImagePreview(url);
				else if (!fileInput.files.length) hideImagePreview();
			});

			function handleFileSelect(input) {
				if (input.files && input.files[0]) {
					const reader = new FileReader();
					reader.onload = (e) => updateImagePreview(e.target.result);
					reader.readAsDataURL(input.files[0]);
					urlInput.value = '';
				}
			}

			function updateImagePreview(src) {
				previewImg.src = src;
				previewContainer.classList.remove('hidden');
			}

			function hideImagePreview() {
				previewContainer.classList.add('hidden');
				previewImg.src = '#';
			}

			function clearImagePreview() {
				urlInput.value = '';
				fileInput.value = '';
				hideImagePreview();
			}

			function hideNewsModal() {
				document.getElementById('newsModal').classList.add('hidden');
				document.body.classList.remove('overflow-hidden');
			}

			function confirmDeleteNews(id, title) {
				const modal = document.getElementById('deleteNewsModal');
				document.getElementById('deleteNewsId').value = id;
				document.getElementById('deleteNewsMessage').innerHTML = `Are you sure you want to permanently remove <strong>"${title}"</strong>?`;
				modal.classList.remove('hidden');
				document.body.classList.add('overflow-hidden');
			}

			function hideDeleteNewsModal() {
				document.getElementById('deleteNewsModal').classList.add('hidden');
				document.body.classList.remove('overflow-hidden');
			}

			window.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') { hideNewsModal(); hideDeleteNewsModal(); }
			});
		</script>
}
