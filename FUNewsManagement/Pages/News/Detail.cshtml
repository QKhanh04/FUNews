@page "{id:int}"
@model FUNewsManagement.Pages.News.DetailModel
@{
    ViewData["Title"] = Model.VM.NewsTitle;
}

<!-- ── BREADCRUMB ──────────────────────────────────────────────── -->
<nav class="flex text-sm text-slate-500 dark:text-slate-400 mb-6">
    <ol class="flex items-center gap-2">
        <li>
            <a asp-page="/Index" class="hover:text-primary transition-colors">Home</a>
        </li>
        <li class="flex items-center gap-2">
            <span>/</span>
            <a asp-page="/Index" class="hover:text-primary transition-colors">News Feed</a>
        </li>
        @if (!string.IsNullOrWhiteSpace(Model.VM.CategoryName))
        {
            <li class="flex items-center gap-2">
                <span>/</span>
                <span class="text-slate-900 dark:text-white font-medium">@Model.VM.CategoryName</span>
            </li>
        }
    </ol>
</nav>

<!-- ── MAIN GRID ───────────────────────────────────────────────── -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

    <!-- ── ARTICLE ──────────────────────────────────────────────── -->
    <article class="lg:col-span-8">

        <!-- Article Header -->
        <header class="mb-8">
            <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-white leading-tight mb-4">
                @Model.VM.NewsTitle
            </h1>
            <!-- Meta -->
            <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 dark:text-slate-400 border-b border-slate-100 dark:border-slate-800 pb-6">
                <div class="flex items-center gap-1 font-bold text-slate-800 dark:text-slate-300">
                    @(Model.VM.CreatedDate?.ToString("MMM dd, yyyy") ?? "")
                </div>
                <span class="text-slate-200 dark:text-slate-700">|</span>
                <div class="flex items-center gap-1">
                    <span>By <strong class="text-primary hover:underline cursor-pointer" style="color: #f57a00 !important;">@Model.VM.CreatedByName</strong> <span class="text-slate-400 dark:text-slate-500">(@Model.VM.CreatedByRole)</span></span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.VM.CategoryName))
                {
                    <span class="text-slate-200 dark:text-slate-700">|</span>
                    <div class="flex items-center gap-1">
                        <span>Category:</span>
                        <a asp-page="/Index" asp-route-categoryId="@Model.VM.CategoryId"
                           class="bg-primary/5 dark:bg-primary/10 text-primary px-3 py-1 rounded font-bold hover:bg-primary/10 transition-colors">
                        @Model.VM.CategoryName
                        </a>
                    </div>
                }
            </div>
        </header>

        <!-- Featured Image -->
        @if (!string.IsNullOrWhiteSpace(Model.VM.ThumbnailUrl))
        {
            <div class="mb-10 overflow-hidden rounded-xl shadow-sm">
                <img class="w-full h-auto object-cover max-h-[500px]"
                     src="@Model.VM.ThumbnailUrl" alt="@Model.VM.NewsTitle" />
            </div>
        }

        <!-- Headline / Lead -->
        @if (!string.IsNullOrWhiteSpace(Model.VM.Headline))
        {
            <p class="text-lg font-medium text-slate-800 dark:text-slate-200 mb-6 leading-relaxed border-l-4 border-primary pl-4 bg-primary/5 dark:bg-primary/10 py-3 rounded-r-lg">
            @Model.VM.Headline
            </p>
        }

        <!-- Article Content -->
        <section class="prose max-w-none text-slate-700 dark:text-slate-300 leading-relaxed space-y-6">
            @if (!string.IsNullOrWhiteSpace(Model.VM.NewsContent))
            {
                @Html.Raw(Model.VM.NewsContent)
            }
            else
            {
                <p class="text-slate-400 italic">No content available.</p>
            }
        </section>

        <!-- Tags & Share -->
        <div class="mt-12 pt-8 border-t border-slate-100 dark:border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-6">
            <!-- Tags -->
            <div class="flex items-center gap-2 flex-wrap text-left">
                @if (Model.VM.Tags.Any())
                {
                    <span class="text-sm font-semibold text-slate-500 dark:text-slate-400">Tags:</span>
                    foreach (var tag in Model.VM.Tags)
                    {
                        <button type="button" onclick="openTagDrawer('@tag.Key', '@tag.Value')" class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 rounded-full text-xs hover:bg-primary hover:text-white transition-colors cursor-pointer inline-block">
                            #@tag.Value
                        </button>
                    }
                }
            </div>
            <!-- Share -->
            <div class="flex items-center gap-3">
                <span class="text-sm font-semibold text-slate-500 dark:text-slate-400">Share:</span>
                <a href="https://www.facebook.com/sharer/sharer.php?u=@Uri.EscapeDataString(HttpContext.Request.Path)"
                   target="_blank"
                   class="p-2 bg-blue-600 text-white rounded-full hover:bg-blue-700 transition-colors">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <button onclick="navigator.clipboard.writeText(window.location.href).then(() => alert('Link copied!'))"
                        class="p-2 bg-slate-800 text-white rounded-full hover:bg-black transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/></svg>
                </button>
            </div>
        </div>

    </article>

    <!-- ── SIDEBAR ───────────────────────────────────────────────── -->
    <aside class="lg:col-span-4 space-y-8 text-left">

        <!-- Related Articles -->
        <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-100 dark:border-slate-800 shadow-sm">
            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-3">
                <span class="w-1.5 h-6 bg-primary rounded-full"></span>
                Related Articles
            </h3>

            @if (Model.VM.RelatedArticles.Any())
            {
                <div class="space-y-6">
                    @foreach (var related in Model.VM.RelatedArticles)
                    {
                        <a asp-page="/News/Detail" asp-route-id="@related.NewsArticleId"
                           class="group flex gap-4">
                            <div class="w-24 h-20 flex-shrink-0 overflow-hidden rounded-lg bg-slate-100 dark:bg-slate-800">
                                @if (!string.IsNullOrWhiteSpace(related.ThumbnailUrl))
                                {
                                    <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                                         src="@related.ThumbnailUrl" alt="@related.NewsTitle" />
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center">
                                        <span class="material-symbols-outlined text-slate-400">newspaper</span>
                                    </div>
                                }
                            </div>
                            <div class="flex flex-col justify-center">
                                <h4 class="text-sm font-bold text-slate-800 dark:text-slate-200 group-hover:text-primary transition-colors line-clamp-2">
                                @related.NewsTitle
                                </h4>
                                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">
                                @(related.CreatedDate?.ToString("MMM dd, yyyy") ?? "")
                                </p>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="text-slate-400 text-sm italic">No related articles found.</p>
            }

            <a asp-page="/Index" asp-route-categoryId="@Model.VM.CategoryId"
               class="block w-full mt-8 py-2 text-sm font-semibold text-center text-primary border border-primary rounded-lg hover:bg-primary hover:text-white transition-colors">
                View All in @(Model.VM.CategoryName ?? "News Feed")
            </a>
        </div>

        <!-- Newsletter -->
        <div class="bg-primary p-6 rounded-xl text-white">
            <h3 class="font-bold text-lg mb-2">Weekly Updates</h3>
            <p class="text-orange-50 text-sm mb-4">
                Get the latest research news and faculty updates delivered to your inbox.
            </p>
            <div class="flex flex-col gap-2">
                <input class="w-full rounded-lg border-none text-slate-800 px-3 py-2 text-sm focus:outline-none dark:bg-slate-800 dark:text-white placeholder:text-slate-500"
                       placeholder="Enter your email" type="email" />
                <button class="bg-white dark:bg-slate-800 text-primary dark:text-white font-bold py-2 rounded-lg hover:bg-orange-50 dark:hover:bg-slate-700 transition-colors text-sm">
                    Subscribe
                </button>
            </div>
        </div>

    </aside>
</div>

<!-- ── SIDE DRAWER ────────────────────────────────────────── -->
<div id="tagDrawerOverlay" class="fixed inset-0 bg-slate-900/50 z-[90] backdrop-blur-[1px] hidden opacity-0 transition-opacity duration-300" onclick="closeTagDrawer()"></div>

<div id="tagDrawer" class="fixed top-0 right-0 h-full w-full md:w-[480px] bg-white dark:bg-slate-900 shadow-2xl z-[100] transform translate-x-full transition-transform duration-300 ease-in-out border-l border-slate-200 flex flex-col text-left">
    <div class="flex items-center justify-between px-6 py-5 border-b border-slate-100 dark:border-slate-800">
        <div>
            <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Discover more</div>
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
                <span class="text-primary">#</span><span id="drawerTagName">Technology</span>
            </h2>
        </div>
        <button type="button" onclick="closeTagDrawer()" class="p-2 rounded-full hover:bg-slate-100 text-slate-500">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>

    <div class="flex-1 overflow-y-auto p-6" id="drawerContent">
        <div id="drawerLoading" class="hidden flex flex-col items-center justify-center mt-10">
            <span class="material-symbols-outlined animate-spin text-primary text-4xl mb-2">progress_activity</span>
            <p class="text-slate-500 text-sm">Loading articles...</p>
        </div>
        <div id="drawerAjaxContent"></div>
        <div class="mt-8 text-center" style="display: none;" id="viewAllTagBtnContainer">
            <a id="viewAllTagBtn" href="#" class="text-primary font-bold text-sm flex items-center justify-center gap-1 mx-auto text-left">
                View all articles
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
        </div>
    </div>
    
    <div class="p-4 border-t border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50">
        <button type="button" class="w-full py-3 px-4 rounded-lg bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-bold text-sm">
            Follow #<span id="drawerFooterTagName">Technology</span>
        </button>
    </div>
</div>

@section Scripts {
    <script>
        function openTagDrawer(tagId, tagName) {
            document.getElementById('drawerTagName').innerText = tagName;
            document.getElementById('drawerFooterTagName').innerText = tagName;
            document.getElementById('viewAllTagBtn').href = '/Index?tagId=' + tagId;
            document.getElementById('viewAllTagBtnContainer').style.display = 'none';

            document.getElementById('drawerLoading').classList.remove('hidden');
            document.getElementById('drawerAjaxContent').innerHTML = '';

            const overlay = document.getElementById('tagDrawerOverlay');
            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.remove('opacity-0'), 10);

            const drawer = document.getElementById('tagDrawer');
            drawer.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden';

            fetch(`/Index?handler=TagDrawerArticles&tagId=${tagId}`)
                .then(response => response.text())
                .then(html => {
                    document.getElementById('drawerLoading').classList.add('hidden');
                    document.getElementById('drawerAjaxContent').innerHTML = html;
                    document.getElementById('viewAllTagBtnContainer').style.display = 'block';
                })
                .catch(error => {
                    document.getElementById('drawerLoading').classList.add('hidden');
                    document.getElementById('drawerAjaxContent').innerHTML = '<p class="text-red-500 text-sm italic">Failed to load articles.</p>';
                });
        }

        function closeTagDrawer() {
            document.getElementById('tagDrawer').classList.add('translate-x-full');
            const overlay = document.getElementById('tagDrawerOverlay');
            overlay.classList.add('opacity-0');
            setTimeout(() => overlay.classList.add('hidden'), 300);
            document.body.style.overflow = '';
        }
    </script>
}
