@page
@model FUNewsManagement.Pages.Category.ManageModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Category Management";
}

<div class="space-y-8">
    <!-- Breadcrumbs -->
    <nav aria-label="Breadcrumb" class="flex text-sm font-medium text-slate-500 mb-6">
        <ol class="flex items-center space-x-2">
            <li><a asp-page="/Index" class="hover:text-primary transition-colors">Home</a></li>
            <li><span class="material-symbols-outlined text-base">chevron_right</span></li>
            <li class="text-slate-900 font-bold">@ViewData["Title"]</li>
        </ol>
    </nav>

    <!-- Page Title & Primary Actions -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-1">
            <h2 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Category Management</h2>
            <p class="text-slate-500 dark:text-slate-400 max-w-xl">
                Organize and classify news stories within the university ecosystem. Categories help students and faculty find relevant content quickly.
            </p>
        </div>
        <button onclick="openCategoryModal()" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white font-bold px-5 py-2.5 rounded-lg transition-all shadow-lg shadow-primary/20 shrink-0">
            <span class="material-symbols-outlined text-lg">add_circle</span>
            <span>Create New Category</span>
        </button>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-5">
            <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-3xl">category</span>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500">Total Categories</p>
                <h3 class="text-2xl font-bold text-slate-900 dark:text-white">@Model.CategoryData.Stats.TotalCount</h3>
                <p class="text-xs text-green-600 font-semibold mt-1 flex items-center">
                    <span class="material-symbols-outlined text-xs mr-1">trending_up</span> +@Model.CategoryData.Stats.GrowthThisMonth this month
                </p>
            </div>
        </div>
        <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-5">
            <div class="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center text-green-600">
                <span class="material-symbols-outlined text-3xl">task_alt</span>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500">Active Categories</p>
                <h3 class="text-2xl font-bold text-slate-900 dark:text-white">@Model.CategoryData.Stats.ActiveCount</h3>
                @{
                    var activePercent = Model.CategoryData.Stats.TotalCount > 0 ? (Model.CategoryData.Stats.ActiveCount * 100 / Model.CategoryData.Stats.TotalCount) : 0;
                }
                <div class="w-24 h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden mt-2">
                    <div class="bg-green-500 h-full" style="width: @activePercent%"></div>
                </div>
            </div>
        </div>
        <div class="bg-white dark:bg-slate-900 p-6 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex items-center gap-5">
            <div class="w-14 h-14 rounded-full bg-slate-100 flex items-center justify-center text-slate-500">
                <span class="material-symbols-outlined text-3xl">folder_off</span>
            </div>
            <div>
                <p class="text-sm font-medium text-slate-500">Unused Categories</p>
                <h3 class="text-2xl font-bold text-slate-900 dark:text-white">@Model.CategoryData.Stats.UnusedCount</h3>
                <p class="text-xs text-slate-400 italic mt-1">No news articles linked</p>
            </div>
        </div>
    </div>

    <!-- Search and Filters Bar -->
    <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 flex flex-wrap gap-4 shadow-sm">
        <form method="get" class="flex-1 min-w-[300px] flex gap-3">
            <div class="flex-1 relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                <input name="search" value="@Model.CategoryData.SearchTerm" class="w-full pl-10 pr-4 py-2 bg-slate-50 dark:bg-slate-800 border-none rounded-lg focus:ring-2 focus:ring-primary/50 text-slate-900 dark:text-white placeholder:text-slate-400 text-sm" placeholder="Search categories by name or description..." type="text"/>
            </div>
            <button type="submit" class="px-5 py-2 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 transition-colors text-sm">Search</button>
            <a asp-page="/Category/Manage" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-500 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors flex items-center">
                <span class="material-symbols-outlined text-xl">restart_alt</span>
            </a>
        </form>
    </div>

    <!-- Data Table Container -->
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Category Name</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Parent Category</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Description</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Status</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">News Articles</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @foreach (var item in Model.CategoryData.Categories)
                    {
                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors group">
                            <td class="px-6 py-5">
                                <div class="flex items-center gap-3">
                                    <div class="size-8 rounded bg-primary/10 flex items-center justify-center text-primary">
                                        <span class="material-symbols-outlined text-xl">folder</span>
                                    </div>
                                    <span class="font-semibold text-slate-900 dark:text-white">@item.CategoryName</span>
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                <span class="text-sm font-medium text-slate-600 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded">
                                    @item.ParentCategoryName
                                </span>
                            </td>
                            <td class="px-6 py-5 text-sm text-slate-600 dark:text-slate-400 max-w-xs truncate">
                                @item.CategoryDesciption
                            </td>
                            <td class="px-6 py-5">
                                @if (item.IsActive)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-400">
                                        Inactive
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-5">
                                <span class="text-sm font-medium text-slate-600 dark:text-slate-400">@item.NewsCount articles</span>
                            </td>
                            <td class="px-6 py-5 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <button onclick='openCategoryModal(@Json.Serialize(item))' 
                                            class="p-1.5 text-slate-400 hover:text-primary hover:bg-primary/10 rounded transition-all">
                                        <span class="material-symbols-outlined text-xl">edit</span>
                                    </button>
                                    <button type="button" 
                                            onclick="confirmDelete('@item.CategoryId', '@item.CategoryName', @item.NewsCount)"
                                            class="p-1.5 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded transition-all">
                                        <span class="material-symbols-outlined text-xl">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="px-6 py-4 bg-slate-50 dark:bg-slate-800/50 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
            <p class="text-sm text-slate-500 dark:text-slate-400 font-medium">
                Showing <span class="text-slate-900 dark:text-white">@(((Model.CategoryData.PageNumber - 1) * Model.CategoryData.PageSize) + 1)</span> to <span class="text-slate-900 dark:text-white">@(Math.Min(Model.CategoryData.PageNumber * Model.CategoryData.PageSize, Model.CategoryData.TotalCount))</span> of <span class="text-slate-900 dark:text-white">@Model.CategoryData.TotalCount</span> categories
            </p>
            <div class="flex items-center gap-2">
                @if (Model.CategoryData.PageNumber > 1)
                {
                    <a asp-page="/Category/Manage" asp-route-pageNumber="@(Model.CategoryData.PageNumber - 1)" asp-route-search="@Model.CategoryData.SearchTerm" class="size-8 flex items-center justify-center border border-slate-200 dark:border-slate-700 rounded text-slate-600 dark:text-slate-400 hover:bg-white dark:hover:bg-slate-800 transition-colors">
                        <span class="material-symbols-outlined text-lg">chevron_left</span>
                    </a>
                }
                
                <button class="size-8 flex items-center justify-center bg-primary text-white rounded font-bold text-sm">@Model.CategoryData.PageNumber</button>
                
                @if (Model.CategoryData.PageNumber * Model.CategoryData.PageSize < Model.CategoryData.TotalCount)
                {
                    <a asp-page="/Category/Manage" asp-route-pageNumber="@(Model.CategoryData.PageNumber + 1)" asp-route-search="@Model.CategoryData.SearchTerm" class="size-8 flex items-center justify-center border border-slate-200 dark:border-slate-700 rounded text-slate-600 dark:text-slate-400 hover:bg-white dark:hover:bg-slate-800 transition-colors">
                        <span class="material-symbols-outlined text-lg">chevron_right</span>
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<!-- Category Create/Edit Modal -->
<div id="categoryModal" class="fixed inset-0 z-[100] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="hideCategoryModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div class="relative inline-block align-bottom bg-white dark:bg-slate-900 rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
            <form id="categoryForm" method="post">
                <input type="hidden" asp-for="CategoryForm.CategoryId" id="modal_CategoryId" />
                <div class="bg-white dark:bg-slate-900 px-4 pt-5 pb-4 sm:p-8 sm:pb-6">
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight" id="modalTitle">Create Category</h3>
                        <button type="button" onclick="hideCategoryModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    </div>
                    
                    <div class="space-y-5">
                        <div class="space-y-2">
                            <label asp-for="CategoryForm.CategoryName" class="text-sm font-bold text-slate-700 dark:text-slate-300">Category Name</label>
                            <input type="text" asp-for="CategoryForm.CategoryName" id="modal_CategoryName" required
                                   class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/50 text-slate-900 dark:text-white text-sm" 
                                   placeholder="e.g., Campus Life, Academic Research"/>
                        </div>

                        <div class="space-y-2">
                            <label asp-for="CategoryForm.CategoryDesciption" class="text-sm font-bold text-slate-700 dark:text-slate-300">Description</label>
                            <textarea asp-for="CategoryForm.CategoryDesciption" id="modal_CategoryDesciption" rows="3" required
                                      class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/50 text-slate-900 dark:text-white text-sm" 
                                      placeholder="Describe what kind of news belong to this category..."></textarea>
                        </div>

                        <div class="space-y-2">
                            <label asp-for="CategoryForm.ParentCategoryId" class="text-sm font-bold text-slate-700 dark:text-slate-300">Parent Category (Optional)</label>
                            <select asp-for="CategoryForm.ParentCategoryId" id="modal_ParentCategoryId"
                                    class="w-full px-4 py-2.5 bg-slate-50 dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/50 text-slate-900 dark:text-white text-sm">
                                <option value="">No Parent (Top Level)</option>
                                @foreach (var cat in Model.CategoryData.AllCategories)
                                {
                                    <option value="@cat.CategoryId">@cat.CategoryName</option>
                                }
                            </select>
                        </div>

                        <div class="flex items-center gap-3 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-xl">
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" name="CategoryForm.IsActive" value="true" @(Model.CategoryForm?.IsActive == true ? "checked" : "") id="modal_IsActive" class="sr-only peer">
                                <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer dark:bg-slate-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-primary transition-all"></div>
                                <span class="ml-3 text-sm font-bold text-slate-700 dark:text-slate-300">Active Status</span>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="bg-slate-50 dark:bg-slate-800/50 px-4 py-4 sm:px-8 sm:flex sm:flex-row-reverse gap-3">
                    <button type="submit" id="submitBtn" class="w-full inline-flex justify-center rounded-xl border border-transparent shadow-lg shadow-primary/20 px-6 py-2.5 bg-primary text-base font-bold text-white hover:bg-primary/90 focus:outline-none sm:ml-3 sm:w-auto sm:text-sm transition-all">
                        Save Changes
                    </button>
                    <button type="button" onclick="hideCategoryModal()" class="mt-3 w-full inline-flex justify-center rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm px-6 py-2.5 bg-white dark:bg-slate-900 text-base font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 focus:outline-none sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm transition-all">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 z-[100] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="hideDeleteModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div class="relative inline-block align-bottom bg-white dark:bg-slate-900 rounded-2xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
            <div class="bg-white dark:bg-slate-900 px-4 pt-5 pb-4 sm:p-8 sm:pb-6">
                <div class="sm:flex sm:items-start">
                    <div id="deleteModalIcon" class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full sm:mx-0 sm:h-10 sm:w-10">
                        <span class="material-symbols-outlined">warning</span>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
                        <h3 class="text-xl leading-6 font-bold text-slate-900 dark:text-white" id="modal-title">Delete Category</h3>
                        <div class="mt-3">
                            <p id="deleteModalMessage" class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"></p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-slate-50 dark:bg-slate-800/50 px-4 py-4 sm:px-8 sm:flex sm:flex-row-reverse gap-3">
                <form id="deleteForm" method="post" asp-page-handler="Delete">
                    <input type="hidden" name="id" id="deleteId"/>
                    <button id="confirmDeleteBtn" type="submit" class="w-full inline-flex justify-center rounded-xl border border-transparent shadow-lg shadow-red-600/20 px-6 py-2.5 bg-red-600 text-base font-bold text-white hover:bg-red-700 focus:outline-none sm:ml-3 sm:w-auto sm:text-sm transition-all">
                        Delete
                    </button>
                </form>
                <button type="button" onclick="hideDeleteModal()" class="mt-3 w-full inline-flex justify-center rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm px-6 py-2.5 bg-white dark:bg-slate-900 text-base font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 focus:outline-none sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm transition-all">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openCategoryModal(category = null) {
            const modal = document.getElementById('categoryModal');
            const form = document.getElementById('categoryForm');
            const title = document.getElementById('modalTitle');
            const submitBtn = document.getElementById('submitBtn');
            
            // Reset form
            form.reset();
            
            if (category) {
                // Edit mode
                title.innerText = 'Edit Category';
                form.setAttribute('action', '?handler=Edit');
                document.getElementById('modal_CategoryId').value = category.categoryId;
                document.getElementById('modal_CategoryName').value = category.categoryName;
                document.getElementById('modal_CategoryDesciption').value = category.categoryDesciption;
                document.getElementById('modal_ParentCategoryId').value = category.parentCategoryId || "";
                document.getElementById('modal_IsActive').checked = category.isActive;
            } else {
                // Create mode
                title.innerText = 'Create Category';
                form.setAttribute('action', '?handler=Create');
                document.getElementById('modal_CategoryId').value = '0';
                document.getElementById('modal_ParentCategoryId').value = '';
                document.getElementById('modal_IsActive').checked = true;
            }
            
            modal.classList.remove('hidden');
            document.body.classList.add('overflow-hidden');
        }

        function hideCategoryModal() {
            document.getElementById('categoryModal').classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
        }

        function confirmDelete(id, name, newsCount) {
            const modal = document.getElementById('deleteModal');
            const message = document.getElementById('deleteModalMessage');
            const iconContainer = document.getElementById('deleteModalIcon');
            const confirmBtn = document.getElementById('confirmDeleteBtn');
            const deleteId = document.getElementById('deleteId');

            deleteId.value = id;
            
            if (newsCount > 0) {
                iconContainer.className = "mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-amber-100 text-amber-600 sm:mx-0 sm:h-10 sm:w-10";
                message.innerHTML = `Cannot delete category <strong>"${name}"</strong> because it contains <strong>${newsCount}</strong> news articles. You must remove or reassign all articles first.`;
                confirmBtn.classList.add('hidden');
            } else {
                iconContainer.className = "mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 text-red-600 sm:mx-0 sm:h-10 sm:w-10";
                message.innerHTML = `Are you sure you want to delete the category <strong>"${name}"</strong>? This action cannot be undone.`;
                confirmBtn.classList.remove('hidden');
            }
            
            modal.classList.remove('hidden');
            document.body.classList.add('overflow-hidden');
        }

        function hideDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
        }

        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                hideCategoryModal();
                hideDeleteModal();
            }
        });
    </script>
}
