@page
@model FUNewsManagement.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}
<div class="max-w-4xl mx-auto py-20 px-4 text-center">
    <span class="material-symbols-outlined text-red-500 text-7xl mb-6">lock_reset</span>
    <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-4">Access Denied</h1>
    <p class="text-lg text-slate-600 dark:text-slate-400 mb-8">You do not have permission to view this resource.</p>
    <a asp-page="/Index" class="inline-flex items-center gap-2 bg-primary text-white font-bold py-3 px-8 rounded-xl hover:bg-primary-hover shadow-lg transition-all">
        <span class="material-symbols-outlined">home</span>
        Return to Home
    </a>
</div>
